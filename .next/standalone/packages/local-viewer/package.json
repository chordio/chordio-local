{
  "name": "@chordio/local",
  "version": "0.1.5",
  "description": "Local prototype viewer for Chordio workbench",
  "bin": {
    "chordio-local": "./bin/cli.mjs"
  },
  "files": [
    ".next/standalone/",
    "bin/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev --port 5555",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "remotion:prepare": "tsx scripts/prepare-video.ts workbench demo-video",
    "preremotion:preview": "pnpm remotion:prepare",
    "remotion:preview": "remotion studio remotion/index.ts",
    "clean:native": "rm -rf .next/standalone/node_modules/.pnpm/@esbuild+* .next/standalone/node_modules/.pnpm/@img+sharp-* .next/standalone/node_modules/.pnpm/@img+sharp-libvips-* .next/standalone/node_modules/@esbuild",
    "prepublishOnly": "npm run build && npm run clean:native",
    "prepare-release": "bash scripts/prepare-release.sh"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^1.0.0",
    "ai": "^4.0.0",
    "dotenv": "^16.4.0",
    "esbuild": "^0.27.3",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.418",
    "@remotion/cli": "^4.0.418",
    "@remotion/renderer": "^4.0.418",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "node-html-parser": "^7.0.2",
    "postcss": "^8.5.6",
    "puppeteer": "^24.37.0",
    "remotion": "^4.0.418",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}